# Password used to sign in at /admin/login
ADMIN_PASSWORD=choose-a-strong-password

# Random string used to sign the admin session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=replace-with-a-long-random-string

# Set automatically by Vercel when you connect a Blob store to this project
# (Storage tab -> Create Blob store -> Connect). Leave unset for local development;
# the app will use the local data/*.json files and public/uploads instead.
# BLOB_READ_WRITE_TOKEN=
