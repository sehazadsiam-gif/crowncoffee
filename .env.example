# Password used to sign in at /manager/login
ADMIN_PASSWORD=choose-a-strong-password

# Random string used to sign the admin/manager session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=replace-with-a-long-random-string

# ── Cloudflare R2 (persistent storage on Vercel) ──────────────────────────────
# Leave all R2_* vars unset for local development — the app will read/write the
# JSON files in /data and serve images from /public/uploads instead.
#
# How to set up (free):
#  1. Create a Cloudflare account → R2 → Create bucket (e.g. "crown-coffee")
#  2. Enable public access on the bucket; copy the Public URL shown
#  3. R2 → Manage R2 API tokens → Create token (Object Read & Write, your bucket)
#  4. Add the five variables below to your Vercel project's Environment Variables

# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_BUCKET_NAME=crown-coffee
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
